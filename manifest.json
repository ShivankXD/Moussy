{
  "manifest_version": 3,
  "name": "MOUSSY",
  "short_name": "MOUSSY",
  "version": "0.1.0",
  "description": "High-performance cyberpunk mouse gesture engine for Chrome. Bind gestures to actions, trigger scripts, and dominate your workflow.",
  "author": "ShivankXD",

  "icons": {
    "16":  "assets/icons/decepticon-icon.png",
    "32":  "assets/icons/decepticon-icon.png",
    "48":  "assets/icons/decepticon-icon.png",
    "128": "assets/icons/decepticon-icon.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "assets/icons/decepticon-icon.png",
      "32":  "assets/icons/decepticon-icon.png",
      "48":  "assets/icons/decepticon-icon.png",
      "128": "assets/icons/decepticon-icon.png"
    },
    "default_title": "MOUSSY — Gesture Config"
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "offscreen",
    "contextMenus",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "assets/sounds/*.mp3",
        "assets/sounds/*.ogg",
        "assets/icons/*.png",
        "premium/premium.html"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "options_ui": {
    "page": "settings/settings.html",
    "open_in_tab": true
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
